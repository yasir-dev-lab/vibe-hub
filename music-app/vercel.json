{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "env": {
    "AUDIOMACK_CONSUMER_KEY": "@audiomack-consumer-key",
    "AUDIOMACK_CONSUMER_SECRET": "@audiomack-consumer-secret",
    "AUDIOMACK_BASE_URL": "@audiomack-base-url",
    "AUDIOMACK_OAUTH_CALLBACK": "@audiomack-oauth-callback"
  }
}
