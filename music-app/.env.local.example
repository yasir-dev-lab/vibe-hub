# Audiomack API Credentials
# Get these from https://audiomack.com/data-api
AUDIOMACK_CONSUMER_KEY=your_consumer_key_here
AUDIOMACK_CONSUMER_SECRET=your_consumer_secret_here

# Audiomack API Base URL
AUDIOMACK_BASE_URL=https://api.audiomack.com/v1

# OAuth Callback URL (for local development)
AUDIOMACK_OAUTH_CALLBACK=http://localhost:3000/api/audiomack/auth/callback

# For production deployment on Vercel, update this to your production URL
# AUDIOMACK_OAUTH_CALLBACK=https://your-domain.com/api/audiomack/auth/callback

# Access Tokens (will be generated after OAuth flow)
# These are automatically populated after successful authentication
AUDIOMACK_ACCESS_TOKEN=
AUDIOMACK_ACCESS_TOKEN_SECRET=
